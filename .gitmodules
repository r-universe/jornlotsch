[submodule ".registry"]
	path = .registry
	url = https://github.com/r-universe-org/cran-to-git
	branch = HEAD
[submodule "EDOtrans"]
	path = EDOtrans
	url = https://github.com/jornlotsch/edotrans
[submodule "detectXOR"]
	path = detectXOR
	url = https://github.com/jornlotsch/detectxor
[submodule "opGMMassessment"]
	path = opGMMassessment
	url = https://github.com/jornlotsch/opgmmassessment
[submodule "opImputation"]
	path = opImputation
	url = https://github.com/jornlotsch/opimputation
[submodule "opdisDownsampling"]
	path = opdisDownsampling
	url = https://github.com/jornlotsch/opdisdownsampling
[submodule "pguIMP"]
	path = pguIMP
	url = https://github.com/jornlotsch/pguimp
